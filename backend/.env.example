# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║              InvestMate — Backend Environment Variables                     ║
# ║  Copy this file to .env and fill in your own values.                        ║
# ║  NEVER commit .env — it is listed in .gitignore.                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── JWT Secret Key ────────────────────────────────────────────────────────────
# Used to sign and verify user auth tokens.
# Generate a secure value with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a random key is generated per server restart (users must re-login on restart).
JWT_SECRET_KEY=your_long_random_secret_here_at_least_32_chars

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# 1. Go to https://mongodb.com/atlas and create a free account
# 2. Create a free M0 cluster (512 MB)
# 3. Under Security → Database Access, create a user with readWrite permissions
# 4. Under Network Access, add 0.0.0.0/0 to allow all IPs (or your specific IP)
# 5. Under Databases → Connect → Drivers → Python, copy the connection string
# 6. Replace <password> with your database user's password
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@cluster0.xxxxx.mongodb.net/StockAnalysis

# ── NewsAPI ───────────────────────────────────────────────────────────────────
# Register at https://newsapi.org/register (free tier: 100 requests/day)
# You can use the same key for both variables, or get two accounts for higher limits
NEWS_API_KEY_MARKET=your_newsapi_key_here
NEWS_API_KEY_STOCK=your_newsapi_key_here

# ── Reddit (optional) ─────────────────────────────────────────────────────────
# Used for social sentiment analysis. Falls back gracefully if not provided.
# 1. Log into Reddit and go to https://www.reddit.com/prefs/apps
# 2. Click "Create App" → choose "script"
# 3. Fill in a name and redirect URI (http://localhost is fine)
# 4. Copy the client_id (below the app name) and secret
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=InvestMate/1.0 by YourRedditUsername
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── Financial Modeling Prep ───────────────────────────────────────────────────
# Used for the stock symbol search autocomplete
# Get a free key at https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_key_here

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Required for the RAG chatbot (text embeddings + LLM responses)
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API key"
# 3. Paste it below
GOOGLE_API_KEY=your_google_gemini_api_key_here
