# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║              InvestMate — Frontend Environment Variables                    ║
# ║  Copy this file to .env and adjust as needed.                               ║
# ║  NEVER commit .env — it is listed in .gitignore.                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# URL of the Flask backend server
# For local development, leave this as-is
# For production, change to your deployed backend URL (e.g. https://api.yourapp.com)
REACT_APP_API_URL=http://127.0.0.1:5000

# Environment label (optional — used for conditional behaviour)
REACT_APP_ENV=development
